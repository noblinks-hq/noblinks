#!/usr/bin/env bash
# noblinks-agent daemon
# Managed by systemd. Sends heartbeats every 30s and syncs
# Prometheus alert rules every 60s.
set -euo pipefail

CONFIG_FILE="${NOBLINKS_CONFIG:-/etc/noblinks/agent.env}"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "ERROR: config not found at $CONFIG_FILE" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

: "${NOBLINKS_URL:?NOBLINKS_URL not set in $CONFIG_FILE}"
: "${AGENT_TOKEN:?AGENT_TOKEN not set in $CONFIG_FILE}"
: "${MACHINE_NAME:?MACHINE_NAME not set in $CONFIG_FILE}"
: "${AGENT_VERSION:?AGENT_VERSION not set in $CONFIG_FILE}"

PROMETHEUS_URL="http://localhost:9090"
RULES_FILE="/etc/prometheus/rules/noblinks.yml"
HEARTBEAT_INTERVAL=30
SYNC_INTERVAL=60
LAST_HEARTBEAT=0
LAST_SYNC=0
LAST_RULES_HASH=""

METRICS_SYNC_INTERVAL=60
LAST_METRICS_SYNC=0
# Populated by sync_metrics_config; each element is "key\tpromql"
METRICS_CONFIG=()

sync_metrics_config() {
  local raw
  raw=$(curl -sf \
    --max-time 10 \
    "${NOBLINKS_URL}/api/agent/metrics-config" \
    -H "Authorization: Bearer ${AGENT_TOKEN}" \
    2>/dev/null \
    || true)

  if [[ -z "$raw" ]]; then
    log "metrics-config: failed to reach server (will retry in ${METRICS_SYNC_INTERVAL}s)"
    return
  fi

  # Parse JSON with Python3 into a bash array of "key<TAB>promql" entries
  local parsed
  parsed=$(python3 - "$raw" <<'PYEOF'
import sys, json
try:
    data = json.loads(sys.argv[1])
    for m in data.get("metrics", []):
        if m.get("key") and m.get("promql"):
            print(m["key"] + "\t" + m["promql"])
except Exception as e:
    import sys as _sys
    print("parse error: " + str(e), file=_sys.stderr)
PYEOF
  ) || true

  METRICS_CONFIG=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && METRICS_CONFIG+=("$line")
  done <<< "$parsed"

  log "metrics-config: ${#METRICS_CONFIG[@]} metric(s) to collect"
  for entry in "${METRICS_CONFIG[@]}"; do
    log "  → $(echo "$entry" | cut -f1)"
  done
}

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] noblinks-agent: $*"
}

is_running() {
  local port="$1"
  if command -v ss &>/dev/null; then
    ss -ltn 2>/dev/null | grep -q ":${port} " && return 0
  elif command -v netstat &>/dev/null; then
    netstat -ltn 2>/dev/null | grep -q ":${port} " && return 0
  fi
  return 1
}

push_metrics() {
  [[ ${#METRICS_CONFIG[@]} -eq 0 ]] && return 0  # no widgets configured yet

  # Build JSON samples array by querying each required metric from Prometheus
  local samples_json
  samples_json=$(python3 - "${PROMETHEUS_URL}" "${METRICS_CONFIG[@]}" <<'PYEOF'
import sys, json, urllib.request, urllib.parse

prometheus_url = sys.argv[1]
entries = sys.argv[2:]  # "key\tpromql" strings

samples = []
for entry in entries:
    if "\t" not in entry:
        continue
    key, promql = entry.split("\t", 1)
    try:
        url = prometheus_url + "/api/v1/query?query=" + urllib.parse.quote(promql)
        with urllib.request.urlopen(url, timeout=5) as r:
            d = json.load(r)
        results = d.get("data", {}).get("result", [])
        if results:
            val = float(results[0]["value"][1])
            samples.append({"metric": key, "value": val})
        else:
            print(f"WARN: no results for {key}", file=sys.stderr)
    except Exception as e:
        print(f"WARN: query failed for {key}: {e}", file=sys.stderr)

print(json.dumps(samples))
PYEOF
  )
  local py_exit=$?
  if [[ $py_exit -ne 0 || -z "$samples_json" ]]; then
    log "metrics: prometheus scrape failed (exit ${py_exit})"
    return 0
  fi

  local sample_count
  sample_count=$(python3 -c "import json,sys; print(len(json.loads(sys.argv[1])))" "$samples_json" 2>/dev/null) || sample_count=0

  if [[ "$sample_count" -eq 0 ]]; then
    log "metrics: 0 samples scraped (prometheus may not have data yet)"
    return 0
  fi

  log "metrics: pushing ${sample_count} sample(s)"
  if ! curl -sf \
      --max-time 10 \
      -X POST "${NOBLINKS_URL}/api/agent/metrics" \
      -H "Authorization: Bearer ${AGENT_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "{\"samples\":${samples_json}}" \
      > /dev/null; then
    log "metrics: push to server failed"
  else
    log "metrics: pushed ${sample_count} sample(s) ok"
  fi
}

send_heartbeat() {
  local prometheus_running alertmanager_running node_exporter_running
  is_running 9090 && prometheus_running=true    || prometheus_running=false
  is_running 9093 && alertmanager_running=true  || alertmanager_running=false
  is_running 9100 && node_exporter_running=true || node_exporter_running=false

  local payload
  payload=$(printf '{"agentVersion":"%s","prometheusRunning":%s,"alertmanagerRunning":%s,"nodeExporterRunning":%s}' \
    "$AGENT_VERSION" "$prometheus_running" "$alertmanager_running" "$node_exporter_running")

  if ! curl -sf \
      --max-time 10 \
      -X POST "${NOBLINKS_URL}/api/agent/heartbeat" \
      -H "Authorization: Bearer ${AGENT_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "$payload" \
      > /dev/null; then
    log "heartbeat failed (will retry in ${HEARTBEAT_INTERVAL}s)"
  fi
}

sync_rules() {
  local new_rules
  new_rules=$(curl -sf \
    --max-time 15 \
    "${NOBLINKS_URL}/api/agent/rules" \
    -H "Authorization: Bearer ${AGENT_TOKEN}" \
    || true)

  if [[ -z "$new_rules" ]]; then
    log "failed to fetch rules, skipping"
    return
  fi

  local new_hash
  new_hash=$(printf '%s' "$new_rules" | sha256sum | awk '{print $1}')

  if [[ "$new_hash" == "$LAST_RULES_HASH" ]]; then
    return  # no change
  fi

  log "rules changed, updating Prometheus"
  printf '%s\n' "$new_rules" > "$RULES_FILE"
  LAST_RULES_HASH="$new_hash"

  # Hot-reload Prometheus (--web.enable-lifecycle must be set)
  if ! curl -sf --max-time 5 -X POST "${PROMETHEUS_URL}/-/reload" > /dev/null; then
    log "prometheus reload failed (rules written but not yet active)"
  fi

  # Extract alert IDs and report them as active
  local alert_ids ids_json
  alert_ids=$(printf '%s' "$new_rules" \
    | grep 'noblinks_alert_id:' \
    | sed 's/.*noblinks_alert_id:[[:space:]]*"\?\([^"[:space:]]*\)"\?.*/\1/' \
    | sort -u \
    || true)

  if [[ -n "$alert_ids" ]]; then
    ids_json=$(printf '%s' "$alert_ids" \
      | awk '{printf "\"%s\",", $0}' \
      | sed 's/,$//')
    curl -sf \
      --max-time 10 \
      -X PATCH "${NOBLINKS_URL}/api/agent/status" \
      -H "Authorization: Bearer ${AGENT_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "{\"activatedAlertIds\":[${ids_json}]}" \
      > /dev/null \
      || log "status update failed"
  fi
}

poll_pending_queries() {
  local response
  response=$(curl -sf \
    --max-time 10 \
    "${NOBLINKS_URL}/api/agent/pending-queries" \
    -H "Authorization: Bearer ${AGENT_TOKEN}" \
    || true)

  [[ -z "$response" ]] && return

  python3 - "$response" "${NOBLINKS_URL}" "${AGENT_TOKEN}" "${PROMETHEUS_URL}" <<'PYEOF'
import sys, json, urllib.request, urllib.parse, http.client

raw, server_url, token, prom_url = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

try:
    queries = json.loads(raw).get("queries", [])
except Exception:
    sys.exit(0)

if not queries:
    sys.exit(0)

print(f"[pending-queries] executing {len(queries)} query/queries", flush=True)

for q in queries:
    qid   = q.get("id", "")
    promql = q.get("promql", "")

    result_payload = None
    try:
        url = prom_url + "/api/v1/query?query=" + urllib.parse.quote(promql)
        with urllib.request.urlopen(url, timeout=10) as r:
            data = json.load(r)
        if data.get("status") != "success":
            raise ValueError("prometheus returned non-success status")
        labels = list({
            m["metric"].get("name")
            for m in data.get("data", {}).get("result", [])
            if m.get("metric", {}).get("name")
        })
        result_payload = json.dumps({"id": qid, "result": labels})
        print(f"[pending-queries] {qid[:8]} → {labels}", flush=True)
    except Exception as e:
        result_payload = json.dumps({"id": qid, "error": str(e)})
        print(f"[pending-queries] {qid[:8]} failed: {e}", file=sys.stderr, flush=True)

    try:
        req = urllib.request.Request(
            server_url + "/api/agent/query-result",
            data=result_payload.encode(),
            headers={"Authorization": f"Bearer {token}", "Content-Type": "application/json"},
            method="POST",
        )
        urllib.request.urlopen(req, timeout=10)
    except Exception as e:
        print(f"[pending-queries] failed to post result: {e}", file=sys.stderr, flush=True)
PYEOF
}

log "starting (machine=${MACHINE_NAME}, version=${AGENT_VERSION})"
log "noblinks URL: ${NOBLINKS_URL}"

# Run immediately on start
send_heartbeat
LAST_HEARTBEAT=$(date +%s)
sync_metrics_config
push_metrics || true
sync_rules
LAST_SYNC=$LAST_HEARTBEAT
LAST_METRICS_SYNC=$LAST_HEARTBEAT

while true; do
  sleep 5

  poll_pending_queries

  NOW=$(date +%s)
  if (( NOW - LAST_HEARTBEAT >= HEARTBEAT_INTERVAL )); then
    send_heartbeat
    push_metrics || true
    LAST_HEARTBEAT=$NOW
  fi
  if (( NOW - LAST_METRICS_SYNC >= METRICS_SYNC_INTERVAL )); then
    sync_metrics_config
    LAST_METRICS_SYNC=$NOW
  fi
  if (( NOW - LAST_SYNC >= SYNC_INTERVAL )); then
    sync_rules
    LAST_SYNC=$NOW
  fi
done
