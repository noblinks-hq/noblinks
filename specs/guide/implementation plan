## PHASE 1 — Blueprint Generator

### 1.1 — Blueprint Data Model

```ts
interface MigrationBlueprint {
  id: string
  userId: string
  organizationId: string
  label: string                     // e.g. "AWS → Hetzner - April 2026"
  sourceCloud: "aws" | "gcp" | "azure"
  targetCloud: "hetzner"            // v1: Hetzner only, expand later
  lensScore: number
  glanceExportId: string            // reference to Glance blueprint export

  // Core content
  resourceMappings: ResourceMapping[]
  networkPlan: NetworkPlan
  migrationWaves: BlueprintWave[]
  gapAnalysis: GapItem[]
  costEstimate: CostEstimate

  // Status
  status: "draft" | "ready" | "in_progress" | "complete"
  migrationProgress: number         // 0–100%, updated as user confirms steps
  createdAt: string
  updatedAt: string
}

interface ResourceMapping {
  id: string
  blueprintId: string
  sourceResourceId: string          // GlanceResource.id
  sourceService: string             // "ec2", "rds", "lambda"
  sourceName: string
  sourceConfig: Record<string, unknown>  // key config from Glance (no secrets)

  // Target — what the user needs to create on Hetzner
  targetService: string             // "hetzner_server", "hetzner_managed_db", etc.
  targetName: string                // user-editable, default = "htz-{sourceName}"
  targetSpec: HetznerResourceSpec   // concrete config the user should create
  equivalenceType: "direct" | "partial" | "workaround" | "gap"
  equivalenceNotes: string          // e.g. "No managed FaaS — use K3s + OpenFaaS"

  // Migration tracking
  migrationWave: number
  migrationEffort: "low" | "medium" | "high"
  migrationStatus: "pending" | "in_progress" | "complete" | "skipped"

  // Validated Hetzner resource (populated after agent confirms it exists)
  hetznerResourceId: number | null  // set after user creates + agent validates
  hetznerResourceType: string | null
  validatedAt: string | null

  // Content
  staticGuide: string               // slug of applicable static guide
  customInstructions: string | null // agent-generated notes for this specific resource
}

// targetSpec describes what the user must create — it is instructions, not a
// provisioning payload. The agent never passes this to the Hetzner API.
type HetznerResourceSpec =
  | HetznerServerSpec
  | HetznerNetworkSpec
  | HetznerManagedDbSpec
  | HetznerObjectStorageSpec
  | HetznerLoadBalancerSpec
  | HetznerFirewallSpec
  | HetznerVolumeSpec
  | HetznerDnsSpec
  | K3sClusterSpec           // K3s = EKS gap workaround
  | OpenFaaSSpec             // OpenFaaS on K3s = Lambda gap workaround
```

