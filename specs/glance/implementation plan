## PHASE 1 — Data Model

### 1.1 — Resource Model (richer than Lens)

Glance needs more detail per resource than Lens:

```ts
interface GlanceResource {
  id: string                    // internal UUID
  cloudId: string               // AWS resource ID (e.g. "i-0abc123", "arn:...")
  service: string               // "ec2", "rds", "lambda", etc.
  name: string | null           // human-readable name (from tags or API)
  type: string | null           // e.g. "t3.large", "db.r6g.large", "nodejs18.x"
  region: string
  accountId: string
  sourceCloud: "aws" | "gcp" | "azure"
  tags: Record<string, string>  // AWS resource tags — valuable for grouping
  config: Record<string, unknown> // full config snapshot (security groups, subnet, etc.)
  stateful: boolean             // databases, EFS, S3 = true; Lambda, EC2 = false
  criticality: "high" | "medium" | "low"  // inferred from service type + usage
  firstSeenAt: string
  lastSeenAt: string
  removedAt: string | null
}
```

### 1.2 — Dependency Model

```ts
interface GlanceDependency {
  id: string
  fromResourceId: string        // points to GlanceResource.id
  toResourceId: string
  type: DependencyType
  confidence: "confirmed" | "inferred"
  evidence: string              // e.g. "shared security group sg-abc123"
  direction: "unidirectional" | "bidirectional"
  critical: boolean             // if this edge breaks, the fromResource likely fails
}

type DependencyType =
  | "network"           // same VPC, security group, subnet
  | "iam"               // IAM role grants access to resource
  | "data"              // reads/writes to database or storage
  | "event"             // SQS trigger, EventBridge rule, Kinesis consumer
  | "compute"           // Lambda backed by container in ECR, ECS pulling from ECR
  | "dns"               // service resolved via Route 53 or Cloud Map
  | "replica"           // RDS read replica → primary
  | "storage"           // mounts EFS, uses S3 bucket
  | "secret"            // reads from Secrets Manager, Parameter Store
```

### 1.3 — Architecture Snapshot

```ts
interface ArchitectureSnapshot {
  id: string
  userId: string
  organizationId: string
  accountId: string
  label: string               // user-defined: "Before migration v1", "Post-Lambda removal"
  resourceCount: number
  dependencyCount: number
  resources: GlanceResource[]
  dependencies: GlanceDependency[]
  migrationWaves: MigrationWave[]
  createdAt: string
}

interface MigrationWave {
  wave: number                  // 1 = move first, higher = move later
  resources: string[]           // GlanceResource.id[]
  rationale: string             // "These services have no incoming dependencies"
  estimatedEffort: "low" | "medium" | "high"
  blockers: string[]            // what must be migrated first
}
```

### 1.4 — Database Schema

```
glance_resource table:
  id, userId, organizationId, accountId, sourceCloud
  cloudId, service, name, type, region
  stateful, criticality, tags (JSONB), config (JSONB)
  firstSeenAt, lastSeenAt, removedAt
  createdAt, updatedAt

glance_dependency table:
  id, userId, organizationId, accountId
  fromResourceId (→ glance_resource.id)
  toResourceId (→ glance_resource.id)
  type, confidence, evidence, direction, critical
  createdAt, updatedAt

glance_snapshot table:
  id, userId, organizationId, accountId, label
  resourceCount, dependencyCount
  resources (JSONB), dependencies (JSONB), migrationWaves (JSONB)
  createdAt
```

