  extra           // JSONB — additional metadata
  firstSeenAt     // when Lens first detected this resource
  lastSeenAt      // updated on every scan
  removedAt       // null if still present, set when no longer detected
  complianceFlags // JSONB — flags that apply to this specific resource
  createdAt, updatedAt
```

